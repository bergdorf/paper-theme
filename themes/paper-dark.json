{
  "$schema": "vscode://schemas/color-theme",
  "name": "Paper Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1A1714",
    "editor.foreground": "#E0D8CC",
    "editorCursor.foreground": "#C8723A",
    "editor.lineHighlightBackground": "#221E1A",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#C89A5040",
    "editor.inactiveSelectionBackground": "#C89A5028",
    "editor.wordHighlightBackground": "#C89A5030",
    "editor.wordHighlightStrongBackground": "#C89A5050",
    "editor.findMatchBackground": "#C89A5050",
    "editor.findMatchHighlightBackground": "#C89A5030",
    "editorWhitespace.foreground": "#3A3530",
    "editorIndentGuide.background1": "#282420",
    "editorIndentGuide.activeBackground1": "#4A4540",
    "editorRuler.foreground": "#282420",
    "editorBracketMatch.background": "#C89A5030",
    "editorBracketMatch.border": "#7A6A5A",
    "editorBracketHighlight.foreground1": "#E0D8CC",
    "editorBracketHighlight.foreground2": "#E0D8CC",
    "editorBracketHighlight.foreground3": "#E0D8CC",
    "editorBracketHighlight.foreground4": "#E0D8CC",
    "editorBracketHighlight.foreground5": "#E0D8CC",
    "editorBracketHighlight.foreground6": "#E0D8CC",
    "editorBracketHighlight.unexpectedBracket.foreground": "#C07880",
    "editorOverviewRuler.border": "#282420",
    "editorLineNumber.foreground": "#4A4540",
    "editorLineNumber.activeForeground": "#9A9288",
    "editorGutter.background": "#1A1714",
    "editorGutter.addedBackground": "#6A9E6A",
    "editorGutter.modifiedBackground": "#9E8E4A",
    "editorGutter.deletedBackground": "#9E6A70",
    "sideBar.background": "#151210",
    "sideBar.foreground": "#E0D8CC",
    "sideBar.border": "#0E0C0A",
    "sideBarTitle.foreground": "#7A7268",
    "sideBarSectionHeader.background": "#121009",
    "sideBarSectionHeader.foreground": "#E0D8CC",
    "sideBarSectionHeader.border": "#0E0C0A",
    "activityBar.background": "#121009",
    "activityBar.foreground": "#E0D8CC",
    "activityBar.inactiveForeground": "#4A4540",
    "activityBar.border": "#0E0C0A",
    "activityBarBadge.background": "#5A7A98",
    "activityBarBadge.foreground": "#E0D8CC",
    "statusBar.background": "#0E0C0A",
    "statusBar.foreground": "#9A9288",
    "statusBar.border": "#080604",
    "statusBar.noFolderBackground": "#0E0C0A",
    "statusBar.debuggingBackground": "#7A4548",
    "statusBar.debuggingForeground": "#E0D8CC",
    "statusBarItem.hoverBackground": "#C89A5025",
    "statusBarItem.remoteBackground": "#5A7A98",
    "statusBarItem.remoteForeground": "#E0D8CC",
    "titleBar.activeBackground": "#151210",
    "titleBar.activeForeground": "#E0D8CC",
    "titleBar.inactiveBackground": "#121009",
    "titleBar.inactiveForeground": "#4A4540",
    "titleBar.border": "#0E0C0A",
    "editorGroupHeader.tabsBackground": "#131110",
    "editorGroupHeader.border": "#0E0C0A",
    "tab.activeBackground": "#1A1714",
    "tab.activeForeground": "#E0D8CC",
    "tab.activeBorder": "#1A1714",
    "tab.activeBorderTop": "#5A7A98",
    "tab.inactiveBackground": "#131110",
    "tab.inactiveForeground": "#6A6460",
    "tab.border": "#0E0C0A",
    "tab.hoverBackground": "#1C1916",
    "panel.background": "#151210",
    "panel.border": "#0E0C0A",
    "panelTitle.activeBorder": "#5A7A98",
    "panelTitle.activeForeground": "#E0D8CC",
    "panelTitle.inactiveForeground": "#6A6460",
    "terminal.background": "#1A1714",
    "terminal.foreground": "#E0D8CC",
    "terminal.ansiBlack": "#2A2622",
    "terminal.ansiRed": "#C07880",
    "terminal.ansiGreen": "#6AA870",
    "terminal.ansiYellow": "#BAA050",
    "terminal.ansiBlue": "#6090C0",
    "terminal.ansiMagenta": "#A080A0",
    "terminal.ansiCyan": "#5098A8",
    "terminal.ansiWhite": "#C8C0B4",
    "terminal.ansiBrightBlack": "#6A6460",
    "terminal.ansiBrightRed": "#E0909A",
    "terminal.ansiBrightGreen": "#8AC890",
    "terminal.ansiBrightYellow": "#D4B870",
    "terminal.ansiBrightBlue": "#80B0E0",
    "terminal.ansiBrightMagenta": "#C0A0C0",
    "terminal.ansiBrightCyan": "#70B8C8",
    "terminal.ansiBrightWhite": "#E0D8CC",
    "terminalCursor.foreground": "#C8723A",
    "input.background": "#1A1714",
    "input.foreground": "#E0D8CC",
    "input.border": "#3A3530",
    "input.placeholderForeground": "#5A5550",
    "inputOption.activeBorder": "#5A7A98",
    "dropdown.background": "#151210",
    "dropdown.foreground": "#E0D8CC",
    "dropdown.border": "#3A3530",
    "button.background": "#5A7A98",
    "button.foreground": "#E0D8CC",
    "button.hoverBackground": "#4A6A88",
    "button.secondaryBackground": "#3A3530",
    "button.secondaryForeground": "#E0D8CC",
    "list.activeSelectionBackground": "#C89A5040",
    "list.activeSelectionForeground": "#E0D8CC",
    "list.inactiveSelectionBackground": "#C89A5025",
    "list.hoverBackground": "#2A2420",
    "list.focusBackground": "#C89A5030",
    "list.highlightForeground": "#6090C0",
    "diffEditor.insertedTextBackground": "#6A9E6A25",
    "diffEditor.removedTextBackground": "#9E6A7025",
    "diffEditor.insertedLineBackground": "#6A9E6A18",
    "diffEditor.removedLineBackground": "#9E6A7018",
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#5A554F50",
    "scrollbarSlider.hoverBackground": "#5A554F80",
    "scrollbarSlider.activeBackground": "#7A746EAA",
    "badge.background": "#5A7A98",
    "badge.foreground": "#E0D8CC",
    "notificationCenterHeader.background": "#151210",
    "notifications.background": "#1A1714",
    "notifications.border": "#0E0C0A",
    "gitDecoration.addedResourceForeground": "#6A9E6A",
    "gitDecoration.modifiedResourceForeground": "#9E8E4A",
    "gitDecoration.deletedResourceForeground": "#9E6A70",
    "gitDecoration.untrackedResourceForeground": "#6A9E6A",
    "gitDecoration.ignoredResourceForeground": "#4A4540",
    "gitDecoration.conflictingResourceForeground": "#9E6A70",
    "focusBorder": "#5A7A9880",
    "foreground": "#E0D8CC",
    "widget.shadow": "#00000050",
    "selection.background": "#C89A5040",
    "icon.foreground": "#9A9288",
    "errorForeground": "#C07880",
    "descriptionForeground": "#7A7268",
    "textLink.foreground": "#6090C0",
    "textLink.activeForeground": "#80B0E0",
    "editorInlayHint.foreground": "#7A7268",
    "editorInlayHint.background": "#4A4540",
    "editorInlayHint.typeForeground": "#7A7268",
    "editorInlayHint.parameterForeground": "#6A6460",
    "editorGhostText.foreground": "#4A4540",
    "editorStickyScroll.background": "#151210",
    "editorStickyScrollHover.background": "#1C1916"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A9AB8",
        "fontStyle": ""
      }
    },
    {
      "name": "Control flow keywords",
      "scope": [
        "keyword.control",
        "keyword.other.using",
        "keyword.other.import",
        "keyword.other.package"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Other keywords",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage (var, let, const, function, class…)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Class and type names",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.struct",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inherited / implemented type reference",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function definitions",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Built-in functions and methods",
      "scope": [
        "support.function",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants (true, false, null, undefined)",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numeric literals",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.other"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Python docstrings",
      "scope": [
        "string.quoted.docstring.multi.python",
        "string.quoted.docstring.raw.multi.python",
        "string.quoted.docstring.single.python",
        "string.quoted.docstring.raw.single.python"
      ],
      "settings": {
        "foreground": "#7A9AB8",
        "fontStyle": ""
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7A746E",
        "fontStyle": ""
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#9A9288",
        "fontStyle": ""
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.decorator",
        "meta.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML tag names",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "HTML/XML attribute values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS property values and units",
      "scope": [
        "support.constant.property-value",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#E0D8CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6090C0",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7A9AB8",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#6AA870"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C07880"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#BAA050"
      }
    },
    {
      "name": "JSX/TSX component names",
      "scope": [
        "support.class.component.jsx",
        "support.class.component.tsx",
        "entity.name.tag.jsx",
        "entity.name.tag.tsx"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TypeScript modifiers (readonly, abstract, declare, override)",
      "scope": [
        "storage.modifier.ts",
        "storage.modifier.tsx"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TypeScript primitive types (string, number, boolean, never…)",
      "scope": [
        "support.type.primitive.ts",
        "support.type.primitive.tsx"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TypeScript type operators (keyof, typeof, infer, satisfies)",
      "scope": [
        "keyword.operator.expression.keyof",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.infer",
        "keyword.operator.expression.satisfies"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust modifiers (pub, mut, move, ref, unsafe, async)",
      "scope": [
        "storage.modifier.rust"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust macros (vec!, println!, todo!…)",
      "scope": [
        "support.macro.rust",
        "meta.macro.rust entity.name.function.macro.rust"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "storage.modifier.lifetime.rust"
      ],
      "settings": {
        "foreground": "#7A9AB8",
        "fontStyle": ""
      }
    },
    {
      "name": "Go type keywords (struct, interface, map, chan)",
      "scope": [
        "keyword.type.go"
      ],
      "settings": {
        "foreground": "#C8BFB2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C07880",
        "fontStyle": ""
      }
    }
  ],
  "semanticTokenColors": {
    "class": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "interface": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "typeParameter": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "enum": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "enumMember": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "namespace": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "decorator": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "macro": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "struct": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "type": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "function": {
      "foreground": "#E0D8CC"
    },
    "function.declaration": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "method": {
      "foreground": "#E0D8CC"
    },
    "method.declaration": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "property": {
      "foreground": "#E0D8CC"
    },
    "parameter": {
      "foreground": "#E0D8CC"
    },
    "variable": {
      "foreground": "#E0D8CC"
    },
    "variable.readonly": {
      "foreground": "#E0D8CC"
    },
    "keyword": {
      "foreground": "#C8BFB2",
      "bold": true
    },
    "operator": {
      "foreground": "#7A746E"
    },
    "comment": {
      "foreground": "#7A9AB8"
    },
    "lifetime": {
      "foreground": "#7A9AB8"
    }
  }
}