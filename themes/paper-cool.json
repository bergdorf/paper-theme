{
  "$schema": "vscode://schemas/color-theme",
  "name": "Paper Cool",
  "type": "light",
  "colors": {
    "editor.background": "#F0F3F6",
    "editor.foreground": "#2C3138",
    "editorCursor.foreground": "#3D8A8A",
    "editor.lineHighlightBackground": "#DCE2EA",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#B8C4D080",
    "editor.inactiveSelectionBackground": "#B8C4D040",
    "editor.wordHighlightBackground": "#B8C4D060",
    "editor.wordHighlightStrongBackground": "#B8C4D090",
    "editor.findMatchBackground": "#A8B8D040",
    "editor.findMatchHighlightBackground": "#A8B8D020",
    "editorWhitespace.foreground": "#C0C8D2",
    "editorIndentGuide.background1": "#D5DAE0",
    "editorIndentGuide.activeBackground1": "#A8B0BA",
    "editorRuler.foreground": "#D5DAE0",
    "editorBracketMatch.background": "#B8C4D050",
    "editorBracketMatch.border": "#8A96A0",
    "editorBracketHighlight.foreground1": "#2C3138",
    "editorBracketHighlight.foreground2": "#2C3138",
    "editorBracketHighlight.foreground3": "#2C3138",
    "editorBracketHighlight.foreground4": "#2C3138",
    "editorBracketHighlight.foreground5": "#2C3138",
    "editorBracketHighlight.foreground6": "#2C3138",
    "editorBracketHighlight.unexpectedBracket.foreground": "#8A5068",
    "editorOverviewRuler.border": "#D5DAE0",
    "editorLineNumber.foreground": "#A8B0BA",
    "editorLineNumber.activeForeground": "#5A6270",
    "editorGutter.background": "#F0F3F6",
    "editorGutter.addedBackground": "#5A8C65",
    "editorGutter.modifiedBackground": "#7A8050",
    "editorGutter.deletedBackground": "#8A5068",
    "sideBar.background": "#E4E8ED",
    "sideBar.foreground": "#2C3138",
    "sideBar.border": "#D0D6DC",
    "sideBarTitle.foreground": "#5A6270",
    "sideBarSectionHeader.background": "#D8DCE2",
    "sideBarSectionHeader.foreground": "#2C3138",
    "sideBarSectionHeader.border": "#C8CED6",
    "activityBar.background": "#D8DCE2",
    "activityBar.foreground": "#2C3138",
    "activityBar.inactiveForeground": "#8A9298",
    "activityBar.border": "#C8CED6",
    "activityBarBadge.background": "#4A7AA8",
    "activityBarBadge.foreground": "#FFFFFF",
    "statusBar.background": "#C0C8D2",
    "statusBar.foreground": "#2C3138",
    "statusBar.border": "#A8B0BA",
    "statusBar.noFolderBackground": "#C0C8D2",
    "statusBar.debuggingBackground": "#8A5068",
    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#A8B0BA40",
    "statusBarItem.remoteBackground": "#4A7AA8",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "titleBar.activeBackground": "#E4E8ED",
    "titleBar.activeForeground": "#2C3138",
    "titleBar.inactiveBackground": "#D8DCE2",
    "titleBar.inactiveForeground": "#8A9298",
    "titleBar.border": "#D0D6DC",
    "editorGroupHeader.tabsBackground": "#D8DCE2",
    "editorGroupHeader.border": "#C8CED6",
    "tab.activeBackground": "#F0F3F6",
    "tab.activeForeground": "#2C3138",
    "tab.activeBorder": "#F0F3F6",
    "tab.activeBorderTop": "#4A7AA8",
    "tab.inactiveBackground": "#D8DCE2",
    "tab.inactiveForeground": "#6A7280",
    "tab.border": "#C8CED6",
    "tab.hoverBackground": "#E0E5EA",
    "panel.background": "#E4E8ED",
    "panel.border": "#C8CED6",
    "panelTitle.activeBorder": "#4A7AA8",
    "panelTitle.activeForeground": "#2C3138",
    "panelTitle.inactiveForeground": "#6A7280",
    "terminal.background": "#F0F3F6",
    "terminal.foreground": "#2C3138",
    "terminal.ansiBlack": "#2C3138",
    "terminal.ansiRed": "#8A5068",
    "terminal.ansiGreen": "#5A8C65",
    "terminal.ansiYellow": "#7A8050",
    "terminal.ansiBlue": "#4070A0",
    "terminal.ansiMagenta": "#6A5888",
    "terminal.ansiCyan": "#307880",
    "terminal.ansiWhite": "#7A8290",
    "terminal.ansiBrightBlack": "#4A5260",
    "terminal.ansiBrightRed": "#B06070",
    "terminal.ansiBrightGreen": "#60A870",
    "terminal.ansiBrightYellow": "#9A9860",
    "terminal.ansiBrightBlue": "#5090C0",
    "terminal.ansiBrightMagenta": "#8878A8",
    "terminal.ansiBrightCyan": "#4098A8",
    "terminal.ansiBrightWhite": "#2C3138",
    "terminalCursor.foreground": "#2C3138",
    "input.background": "#F0F3F6",
    "input.foreground": "#2C3138",
    "input.border": "#C0C8D2",
    "input.placeholderForeground": "#A0A8B2",
    "inputOption.activeBorder": "#4A7AA8",
    "dropdown.background": "#E4E8ED",
    "dropdown.foreground": "#2C3138",
    "dropdown.border": "#C0C8D2",
    "button.background": "#4A7AA8",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#3A6A98",
    "button.secondaryBackground": "#C0C8D2",
    "button.secondaryForeground": "#2C3138",
    "list.activeSelectionBackground": "#B8C4D090",
    "list.activeSelectionForeground": "#2C3138",
    "list.inactiveSelectionBackground": "#B8C4D050",
    "list.hoverBackground": "#D5DAE080",
    "list.focusBackground": "#B8C4D070",
    "list.highlightForeground": "#4070A0",
    "diffEditor.insertedTextBackground": "#5A8C6520",
    "diffEditor.removedTextBackground": "#A0606020",
    "diffEditor.insertedLineBackground": "#5A8C6514",
    "diffEditor.removedLineBackground": "#A0606014",
    "scrollbar.shadow": "#00000014",
    "scrollbarSlider.background": "#B8C4D070",
    "scrollbarSlider.hoverBackground": "#B8C4D0A0",
    "scrollbarSlider.activeBackground": "#8A96A0C0",
    "badge.background": "#4A7AA8",
    "badge.foreground": "#FFFFFF",
    "notificationCenterHeader.background": "#E4E8ED",
    "notifications.background": "#F0F3F6",
    "notifications.border": "#C8CED6",
    "gitDecoration.addedResourceForeground": "#5A8C65",
    "gitDecoration.modifiedResourceForeground": "#7A8050",
    "gitDecoration.deletedResourceForeground": "#8A5068",
    "gitDecoration.untrackedResourceForeground": "#5A8C65",
    "gitDecoration.ignoredResourceForeground": "#A0A8B2",
    "gitDecoration.conflictingResourceForeground": "#8A5068",
    "focusBorder": "#4A7AA880",
    "foreground": "#2C3138",
    "widget.shadow": "#00000018",
    "selection.background": "#B8C4D080",
    "icon.foreground": "#5A6270",
    "errorForeground": "#8A5068",
    "descriptionForeground": "#6A7280",
    "textLink.foreground": "#4070A0",
    "textLink.activeForeground": "#2A5080",
    "editorInlayHint.foreground": "#8A98A8",
    "editorInlayHint.background": "#E4E8ED",
    "editorInlayHint.typeForeground": "#8A98A8",
    "editorInlayHint.parameterForeground": "#9098A4",
    "editorGhostText.foreground": "#A8B0BA",
    "editorStickyScroll.background": "#E4E8ED",
    "editorStickyScrollHover.background": "#DCE2EA"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A8A72",
        "fontStyle": ""
      }
    },
    {
      "name": "Control flow keywords",
      "scope": [
        "keyword.control",
        "keyword.other.using",
        "keyword.other.import",
        "keyword.other.package"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Other keywords",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Class and type names",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.struct",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function definitions",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Language constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numeric literals",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.other"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Escape sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Python docstrings",
      "scope": [
        "string.quoted.docstring.multi.python",
        "string.quoted.docstring.raw.multi.python",
        "string.quoted.docstring.single.python",
        "string.quoted.docstring.raw.single.python"
      ],
      "settings": {
        "foreground": "#7A8A72",
        "fontStyle": ""
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#8A96A0",
        "fontStyle": ""
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#525A64",
        "fontStyle": ""
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.decorator",
        "meta.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML tag names",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "HTML attribute values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#2C3138",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#4070A0",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7A8A72",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#5A8C65"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#8A5068"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#7A8050"
      }
    },
    {
      "name": "JSX/TSX components",
      "scope": [
        "support.class.component.jsx",
        "support.class.component.tsx",
        "entity.name.tag.jsx",
        "entity.name.tag.tsx"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TS modifiers",
      "scope": [
        "storage.modifier.ts",
        "storage.modifier.tsx"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TS primitive types",
      "scope": [
        "support.type.primitive.ts",
        "support.type.primitive.tsx"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TS type operators",
      "scope": [
        "keyword.operator.expression.keyof",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.infer",
        "keyword.operator.expression.satisfies"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust modifiers",
      "scope": [
        "storage.modifier.rust"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "meta.macro.rust entity.name.function.macro.rust"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "storage.modifier.lifetime.rust"
      ],
      "settings": {
        "foreground": "#7A8A72",
        "fontStyle": ""
      }
    },
    {
      "name": "Go type keywords",
      "scope": [
        "keyword.type.go"
      ],
      "settings": {
        "foreground": "#464D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#8A5068",
        "fontStyle": ""
      }
    }
  ],
  "semanticTokenColors": {
    "class": {
      "foreground": "#464D56",
      "bold": true
    },
    "interface": {
      "foreground": "#464D56",
      "bold": true
    },
    "typeParameter": {
      "foreground": "#464D56",
      "bold": true
    },
    "enum": {
      "foreground": "#464D56",
      "bold": true
    },
    "enumMember": {
      "foreground": "#464D56",
      "bold": true
    },
    "namespace": {
      "foreground": "#464D56",
      "bold": true
    },
    "decorator": {
      "foreground": "#464D56",
      "bold": true
    },
    "macro": {
      "foreground": "#464D56",
      "bold": true
    },
    "struct": {
      "foreground": "#464D56",
      "bold": true
    },
    "type": {
      "foreground": "#464D56",
      "bold": true
    },
    "function": {
      "foreground": "#2C3138"
    },
    "function.declaration": {
      "foreground": "#464D56",
      "bold": true
    },
    "method": {
      "foreground": "#2C3138"
    },
    "method.declaration": {
      "foreground": "#464D56",
      "bold": true
    },
    "property": {
      "foreground": "#2C3138"
    },
    "parameter": {
      "foreground": "#2C3138"
    },
    "variable": {
      "foreground": "#2C3138"
    },
    "variable.readonly": {
      "foreground": "#2C3138"
    },
    "keyword": {
      "foreground": "#464D56",
      "bold": true
    },
    "operator": {
      "foreground": "#8A96A0"
    },
    "comment": {
      "foreground": "#7A8A72"
    },
    "lifetime": {
      "foreground": "#7A8A72"
    }
  }
}